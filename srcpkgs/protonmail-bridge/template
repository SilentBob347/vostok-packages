# Template file for 'protonmail-bridge'
pkgname=protonmail-bridge
version=3.25.0
revision=1
archs="x86_64"
wrksrc="protonmail-bridge-${version}"
hostmakedepends="libarchive"
short_desc="Proton Mail Bridge - integrate Proton Mail with your email client"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://proton.me/mail/bridge"
distfiles="https://github.com/ProtonMail/proton-bridge/releases/download/v${version}/protonmail-bridge_${version}-1_amd64.deb"
checksum=6b0318f4f425ef1a19b63e2bd589bc1036d95f073cb9ac26b42c0fc63a8bc275
nostrip=yes
noshlibs=yes
noverifyrdeps=yes

depends="libsecret libgbm eudev-libudev alsa-lib libcups libpulseaudio gtk+3 xcb-util-cursor libfido2"

do_extract() {
    mkdir -p "${wrksrc}"
    bsdtar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/protonmail-bridge_${version}-1_amd64.deb \
        -C "${wrksrc}" --include='data.tar*'
    bsdtar -xf "${wrksrc}"/data.tar.* -C "${wrksrc}"
    rm "${wrksrc}"/data.tar.*
}

do_install() {
    vcopy "usr/*" usr
    vcopy "opt/*" opt 2>/dev/null || true

    rm -f ${DESTDIR}/usr/share/applications/protonmail-bridge.desktop
    vmkdir usr/share/applications
    vinstall ${FILESDIR}/protonmail-bridge.desktop 644 usr/share/applications

    if [ -f "usr/share/doc/protonmail/bridge/LICENSE" ]; then
        vlicense usr/share/doc/protonmail/bridge/LICENSE
    else
        vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
    fi
}