# Template file for 'chatbox'
pkgname=chatbox
version=1.20.3
revision=1
archs="x86_64"
wrksrc="chatbox-${version}"
short_desc="Chatbox: Desktop client for AI chat models"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="MIT"
homepage="https://github.com/chatboxai/chatbox"
distfiles="https://github.com/chatboxai/chatbox/releases/download/v${version}/Chatbox-${version}-amd64.deb"
checksum=7a5b86200c180142ee7d4ed5d56edaabba3a3b37b3b8d8c4eed32678d327e141
nostrip=yes
noshlibs=yes
noverifyrdeps=yes

depends="libsecret libgbm eudev-libudev alsa-lib libcups libpulseaudio"

do_extract() {
    mkdir -p ${wrksrc}
    bsdtar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/Chatbox-${version}-amd64.deb \
        -C ${wrksrc} --include='data.tar*'
    bsdtar -xf ${wrksrc}/data.tar* -C ${wrksrc}
    rm ${wrksrc}/data.tar*
}

do_install() {
    vmkdir opt
    vcopy opt/Chatbox opt/chatbox
    find ${DESTDIR}/opt/chatbox -xtype l -delete
    find ${DESTDIR}/opt/chatbox -name "* *" -exec rm -rf {} +
    find ${DESTDIR}/opt/chatbox -type f -links +1 | while IFS= read -r f; do
        cp --remove-destination "${f}" "${f}.tmp"
        mv "${f}.tmp" "${f}"
    done

    vmkdir usr/bin
    ln -sf /opt/chatbox/xyz.chatboxapp.app ${DESTDIR}/usr/bin/chatbox

    vmkdir usr/share/icons/hicolor/256x256/apps
    vinstall opt/Chatbox/resources/assets/icon.png 644 usr/share/icons/hicolor/256x256/apps chatbox.png

    vmkdir usr/share/pixmaps
    vinstall opt/Chatbox/resources/assets/icon.png 644 usr/share/pixmaps chatbox.png

    vmkdir usr/share/applications
    vinstall ${FILESDIR}/chatbox.desktop 644 usr/share/applications

    vinstall opt/Chatbox/LICENSE.electron.txt 644 usr/share/licenses/${pkgname}
}